{
  "name": "contoso-travel-agent-nodejs",
  "version": "1.0.0",
  "description": "Contoso Travel Agent - Node.js Backend Migration",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": ["travel", "agent", "ai", "aws", "nodejs"],
  "author": "Contoso Travel Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.31.0",
    "@aws-lambda-powertools/metrics": "^2.31.0",
    "@aws-lambda-powertools/tracer": "^2.31.0",
    "@aws-sdk/client-bedrock": "^3.995.0",
    "@aws-sdk/client-bedrock-runtime": "^3.995.0",
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/lib-dynamodb": "^3.995.0",
    "@langchain/aws": "^1.2.4",
    "@opentelemetry/api": "^1.9.0",
    "@types/aws-lambda": "^8.10.160",
    "ai": "^6.0.97",
    "inversify": "^7.11.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-client": "^2.1.0",
    "langchain": "^1.2.25",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "aws-lambda-test-utils": "^1.3.0",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
